{
  "name": "meetingmind",
  "version": "1.0.0",
  "description": "Record meetings, transcribe with AssemblyAI, generate notes with Claude AI",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm run build:main && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "package": "npm run build && electron-builder",
    "package:dmg": "npm run build && electron-builder --mac dmg"
  },
  "author": "Noah",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "assemblyai": "^4.26.1",
    "electron-store": "^8.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "keytar": "^7.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "build": {
    "appId": "com.meetingmind.app",
    "productName": "MeetingMind",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "minimumSystemVersion": "12.0",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "bin/ffmpeg",
          "to": "bin/ffmpeg"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
